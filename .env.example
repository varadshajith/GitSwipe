# Example .env file for GitSwipe
# Copy this file to .env and fill in the actual values.

# FastAPI / JWT settings
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database connection (PostgreSQL example)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/git_swipe_db

# GitHub OAuth credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional: OpenAI / Groq API keys for LLM integration
GROQ_API_KEY=your_groq_api_key

# Logging level
LOG_LEVEL=INFO
